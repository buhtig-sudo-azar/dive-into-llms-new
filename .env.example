# OPENROUTER_API_KEY: Required for AI chat via OpenRouter (free models).
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# GEMINI_API_KEY: Optional — for real embeddings via Google Gemini API.
# Without it, embeddings fall back to simulation mode.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"
